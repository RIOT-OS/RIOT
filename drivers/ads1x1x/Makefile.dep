FEATURES_REQUIRED += periph_gpio_irq
FEATURES_REQUIRED += periph_i2c
USEMODULE += ztimer
USEMODULE += ztimer_msec

ifneq (,$(filter ads101x,$(USEMODULE)))
  USEMODULE += ads1x1x
endif

ifneq (,$(filter ads111x,$(USEMODULE)))
  USEMODULE += ads1x1x
endif

ifeq (,$(filter ads111x ads101x,$(USEMODULE)))
  # enable ads101x as default if no other module is enabled
  USEMODULE += ads101x
endif
