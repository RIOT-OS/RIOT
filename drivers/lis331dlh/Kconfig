config MODULE_LIS331DLH
    bool "LIS331DLH 3-axis accelerometer"
    depends on HAS_PERIPH_I2C
    depends on TEST_KCONFIG
    select MODULE_PERIPH_I2C

config HAVE_LIS331DLH
    bool
    select MODULE_LIS331DLH if MODULE_SAUL_DEFAULT
    help
        Indicates that a LIS331DLH accelerometer is present.
