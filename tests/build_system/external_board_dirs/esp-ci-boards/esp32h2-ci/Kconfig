config BOARD
    default "esp32h2-ci" if BOARD_ESP32H2_CI

config BOARD_ESP32H2_CI
    bool
    default y
    select BOARD_COMMON_ESP32H2
    select CPU_MODEL_ESP32H2_MINI_1X_H4S

source "$(RIOTBOARD)/common/esp32h2/Kconfig"
