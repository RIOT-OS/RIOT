config BOARD
    default "esp32c6-ci" if BOARD_ESP32C6_CI

config BOARD_ESP32C6_CI
    bool
    default y
    select BOARD_COMMON_ESP32C6
    select CPU_MODEL_ESP32C6_MINI_1X_X4

source "$(RIOTBOARD)/common/esp32c6/Kconfig"
