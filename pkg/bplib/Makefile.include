INCLUDES += -I$(PKGDIRBASE)/bplib/aa/arp/inc
INCLUDES += -I$(PKGDIRBASE)/bplib/aa/as/inc
INCLUDES += -I$(PKGDIRBASE)/bplib/aa/fwp/inc
INCLUDES += -I$(PKGDIRBASE)/bplib/aa/nc/inc

INCLUDES += -I$(PKGDIRBASE)/bplib/bpa/bi/inc
INCLUDES += -I$(PKGDIRBASE)/bplib/bpa/ct/inc
INCLUDES += -I$(PKGDIRBASE)/bplib/bpa/ebp/inc
INCLUDES += -I$(PKGDIRBASE)/bplib/bpa/pdb/inc
INCLUDES += -I$(PKGDIRBASE)/bplib/bpa/pi/inc
INCLUDES += -I$(PKGDIRBASE)/bplib/bpa/stor/inc

INCLUDES += -I$(PKGDIRBASE)/bplib/ci/cbor/inc
INCLUDES += -I$(PKGDIRBASE)/bplib/ci/crc/inc
INCLUDES += -I$(PKGDIRBASE)/bplib/ci/eid/inc
INCLUDES += -I$(PKGDIRBASE)/bplib/ci/em/inc
INCLUDES += -I$(PKGDIRBASE)/bplib/ci/mem/inc
INCLUDES += -I$(PKGDIRBASE)/bplib/ci/pl/inc
INCLUDES += -I$(PKGDIRBASE)/bplib/ci/qm/inc
INCLUDES += -I$(PKGDIRBASE)/bplib/ci/rbt/inc
INCLUDES += -I$(PKGDIRBASE)/bplib/ci/time/inc

INCLUDES += -I$(PKGDIRBASE)/bplib/cla/inc

INCLUDES += -I$(PKGDIRBASE)/bplib/inc

INCLUDES += -I$(PKGDIRBASE)/bplib/version/inc

INCLUDES += -I$(RIOTPKG)/bplib/fwp/include
INCLUDES += -I$(RIOTPKG)/bplib/nc/include
INCLUDES += -I$(RIOTPKG)/bplib/init/include

# Conditional modules
ifneq (,$(filter bplib_cla_ble,$(USEMODULE)))
  INCLUDES += -I$(RIOTPKG)/bplib/cla/ble/include
endif

ifneq (,$(filter bplib_cla_udp,$(USEMODULE)))
  INCLUDES += -I$(RIOTPKG)/bplib/cla/udp/include
endif

ifneq (,$(filter bplib_stor_vfs_%,$(USEMODULE)))
  INCLUDES += -I$(RIOTPKG)/bplib/storage/vfs/include
endif

PSEUDOMODULES += bplib_barebones
PSEUDOMODULES += bplib_walltime_available
PSEUDOMODULES += bplib_include_nc_telemetry
PSEUDOMODULES += bplib_include_as
PSEUDOMODULES += bplib_no_vfs

ARCHIVES += $(BINDIR)/libbplib.a