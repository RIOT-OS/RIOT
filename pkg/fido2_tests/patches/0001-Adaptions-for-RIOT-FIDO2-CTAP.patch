 	$(PYTHON) -m venv venv
 	$(BIN)/python -m pip install -U pip
 	$(BIN)/pip install -U -r requirements.txt
-	$(BIN)/pip install -U -r dev-requirements.txt
-	$(BIN)/pre-commit install
 
 # re-run if  dependencies change
 update:
 	$(BIN)/python -m pip install -U pip
 	$(BIN)/pip install -U -r requirements.txt
-	$(BIN)/pip install -U -r dev-requirements.txt
 
 # ensure this passes before commiting
 check:
@@ -48,3 +42,7 @@ black:
 
