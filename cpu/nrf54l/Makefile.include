# The nRF54L15 provides 1524 KiB of RRAM (used as flash) and 256 KiB of SRAM
ROM_LEN ?= 0x17D000
RAM_LEN ?= 0x40000

PROGRAMMER ?= jlink
JLINK_DEVICE = NRF54L15_M33

# Select the application core of the nRF54L15 in the vendor header files
CFLAGS += -DNRF54L15_XXAA -DNRF_APPLICATION

include $(RIOTCPU)/nrf5x_common/Makefile.include
include $(RIOTMAKE)/arch/cortexm.inc.mk
