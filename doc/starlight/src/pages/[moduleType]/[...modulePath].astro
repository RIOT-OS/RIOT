import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { LinkCard, Code, Aside, CardGrid } from "@astrojs/starlight/components";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const moduleTypes = ["boards", "cpus"] as const;

  return (
    await Promise.all(
      moduleTypes.map(async (moduleType) => {
        const modules = await getCollection(moduleType);

        return modules.map((module) => {
          // Find related modules such as parents or children
          const relatedModules = modules.filter(
            (item) =>
              item.data.parentId === module.id ||
              item.id === module.data.parentId,
          );

          switch (moduleType) {
            case "boards":
              return {
                params: {
                  moduleType: moduleType,
                  modulePath: module.id,
                },
                props: {
                  module: module,
                  relatedModules: relatedModules,
                  title: "RIOT Boards",
                  descriptionFallback: "CPU documentation",
                  relatedModulesTitle: "Related Boards",
                },
              };

            case "cpus":
              return {
                params: {
                  moduleType: moduleType,
                  modulePath: module.id,
                },
                props: {
                  module: module,
                  relatedModules: relatedModules,
                  title: "RIOT CPUs",
                  descriptionFallback: "CPU documentation",
                  relatedModulesTitle: "Related CPUs",
                },
              };
          }
        });
      }),
    )
  ).flat();
}

const { moduleType } = Astro.params;
const { module, relatedModules, descriptionFallback, relatedModulesTitle } =
  Astro.props;
const { Content, headings } = await render(module);
---

<StarlightPage
  frontmatter={{
    title: module.data.title,
    description: module.data.description || descriptionFallback,
    editUrl: `https://github.com/RIOT-OS/RIOT/tree/master/${module.filePath}`,
  }}
  headings={headings}
>
  <Aside type="caution">
    This page is automatically generated from RIOT doxygen documentation. If you
    find any issues or have suggestions for improvement, please report them on
    <a href="https://github.com/RIOT-OS/RIOT/issues/22203">Github</a>
  </Aside>

  <CardGrid>
    <LinkCard
      title="View API Documentation"
      href={`https://api.riot-os.org/group__${module.data.doxygenGroup}.html`}
      description="View API documentation generated by Doxygen."
    />

    <LinkCard
      title="View on GitHub"
      href={`https://github.com/RIOT-OS/RIOT/tree/master/${module.data.githubFolder}`}
      description="View this source code on GitHub."
    />
  </CardGrid>

  {module.data.description && <p>{module.data.description}</p>}

  {
    relatedModules.length > 0 && (
      <>
        <h4>{relatedModulesTitle}</h4>
        <CardGrid>
          {relatedModules.map((relatedModule) => (
            <LinkCard
              title={relatedModule.data.title}
              description={
                relatedModule.data.description || descriptionFallback
              }
              href={`/${moduleType}/${relatedModule.id}`}
            />
          ))}
        </CardGrid>
      </>
    )
  }

  {
    moduleType === "boards" && (
      <Aside type="tip">
        When using this board with RIOT, set the <code>BOARD</code> variable to{" "}
        <code>{module.id}</code> in your Makefile. If you follow the standard
        RIOT project structure, your Makefile should look like this:
        <Code
          lang="sh"
          code={`
# name of your application
APPLICATION = hello-world

# Change this to your board if you want to build for a different board
BOARD ?= ${module.id}

# This has to be the absolute path to the RIOT base directory:
RIOTBASE ?= $(CURDIR)/RIOT

include $(RIOTBASE)/Makefile.include
`}
          title="./Makefile"
          frame="code"
          mark={[module.id]}
        />
      </Aside>
    )
  }
  <Content />
</StarlightPage>
